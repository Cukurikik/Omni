{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "ESNext", "DOM"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["omni/**/*.ts", "ts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
