// ═══════════════════════════════════════════════
// OMNI PHASE 1 — Language Essentials Test Suite
// ═══════════════════════════════════════════════

// 1. ARRAY LITERAL
let numbers = [1, 2, 3, 4, 5];
let names = ["Omni", "Rust", "Julia"];
let empty = [];
print("✅ 1. Array Literal:");
print(numbers);
print(names);

// 2. OBJECT LITERAL
let config = { host: "localhost", port: 8080 };
let user = { name: "OMNI Developer", age: 25, active: true };
print("✅ 2. Object Literal:");
print(config);
print(user);

// 3. INDEX ACCESS
let first = numbers[0];
let lang = names[1];
print("✅ 3. Index Access:");
print(first);
print(lang);

// 4. LAMBDA / ARROW FUNCTIONS
let double = (x) => x * 2;
let add = (a, b) => a + b;
print("✅ 4. Lambda Functions:");
print(double(21));
print(add(30, 12));

// 5. LAMBDA WITH METHODS
let doubled = numbers.map((x) => x * 2);
print("✅ 5. Lambda + Array.map:");
print(doubled);

// 6. TEMPLATE LITERALS
let name = "OMNI";
let version = 2;
let greeting = `Hello from ${name} v${version}!`;
print("✅ 6. Template Literals:");
print(greeting);

// 7. NEGATIVE NUMBERS
let negative = -42;
let diff = 100 + -50;
print("✅ 7. Negative Numbers:");
print(negative);
print(diff);

// 8. NESTED STRUCTURES
let matrix = [[1, 2], [3, 4], [5, 6]];
let row = matrix[1];
print("✅ 8. Nested Structures:");
print(matrix);
print(row);

// 9. COMBINED: Everything together
fn calculate_stats(data) {
    let total = data.reduce((sum, x) => sum + x, 0);
    let count = data.length;
    return { total: total, count: count };
}
let stats = calculate_stats([10, 20, 30, 40]);
print("✅ 9. Combined Test (calculate_stats):");
print(stats);

// 10. TEMPLATE WITH EXPRESSION
let result = `The answer is ${40 + 2}`;
print("✅ 10. Template + Expression:");
print(result);

print("═══════════════════════════════════════");
print("🎉 ALL PHASE 1 TESTS COMPLETE!");
print("═══════════════════════════════════════");
