// ═══ Struct: Entitas Auth ═══
struct Akun {
    id: String,
    email: String,
    password_hash: String,
    role: String,
}

struct Sesi {
    token: String,
    user_id: String,
    expired_at: Int,
    is_active: Bool,
}

struct Izin {
    role: String,
    resource: String,
    aksi: String,
}

