// Example: Advanced pipeline with omni-cockroachdb
import { DataPipeline } from '@omni/omni-cockroachdb/compute'
import { TypeSafeClient } from '@omni/omni-cockroachdb/ui'

fn main() {
    let pipeline = DataPipeline::new()
        .add_stage('fetch', |_| client.get('/data'))
        .add_stage('transform', |d| d.map(|x| x * 2))
        .add_stage('store', |d| client.post('/results', d))
    pipeline.execute(None)?
}