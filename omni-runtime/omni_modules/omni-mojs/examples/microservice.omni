// Example: Microservice with omni-mojs
import { HTTPServer } from '@omni/omni-mojs/network'
import { DomainService } from '@omni/omni-mojs/domain'

fn main() {
    let svc = DomainService::new()
    let server = HTTPServer::new(3000)
    server.handle('/api/v1/entities', svc.handler())
    server.handle('/health', server.health_check())
    server.start()
}