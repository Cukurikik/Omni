// Example: Batch processing with omni-zod-native
import { JobQueue, Job } from '@omni/omni-zod-native/compute'

fn main() {
    let queue = JobQueue::new()
    for i in 0..1000 { queue.enqueue(Job::new(|_| process(i))) }
    let results = queue.process_all()
    println!("Processed: {} jobs", results.len())
}